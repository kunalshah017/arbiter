# AI Model Configuration
OPENAI_API_KEY="your_openai_api_key_here"

# CoinMarketCap (CMC) Agent Hub Integration
CMC_API_KEY="your_cmc_api_key_here"

# Runtime Environment & Risk Framework
ENVIRONMENT="testnet"
LOG_LEVEL="INFO"
