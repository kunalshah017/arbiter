

# AI Model Configuration
OPENAI_API_KEY="your_openai_api_key_here"
# ANTHROPIC_API_KEY="your_anthropic_api_key_here"  # Uncomment if using Claude instead of GPT-4

# CoinMarketCap (CMC) Agent Hub Integration
CMC_API_KEY="your_cmc_api_key_here"
# Note: For x402 payments, TWAK handles the wallet connections, but CMC may still require an API key or dedicated endpoint.

# Blockchain & Trust Wallet Agent Kit (TWAK) Execution
BSC_RPC_URL="https://bsc-dataseed.binance.org/"
WALLET_PRIVATE_KEY="your_wallet_private_key_here"  # Keep this safe! Never commit the actual .env file to version control.

# BNB AI Agent SDK Configuration (ERC-8004)
AGENT_IDENTITY_ID="your_erc_8004_identity_id"

# Database Configuration
DATABASE_URL="sqlite:///./data/arbiter.db"

# Agent Trading & Risk Parameters (Optional Overrides)
ENVIRONMENT="testnet"               # 'testnet' or 'mainnet'
LOG_LEVEL="INFO"
MAX_DRAWDOWN_PERCENT=25             # Agent halts if daily drawdown exceeds this
MAX_POSITION_SIZE_PERCENT=5         # Max % of portfolio per token
