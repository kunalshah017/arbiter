# Binance (no API key needed for public endpoints)
# CMC MCP (for regime classification + token discovery)
CMC_API_KEY=your-coinmarketcap-api-key

# OpenAI (for regime classification)
OPENAI_API_KEY=sk-...

# LLM API (set at least one — both are free)
# NVIDIA NIM: get key at https://build.nvidia.com/settings/api-keys
NVIDIA_API_KEY=nvapi-...
# Google Gemini: get key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# BNB Agent SDK / Wallet Credentials
ARBITER_PRIVATE_KEY=0xyour_private_key_here
ARBITER_WALLET_PASSWORD=your-secure-password
NETWORK=bsc-mainnet
BSC_RPC_URL=https://bsc-dataseed.binance.org/

# Trust Wallet Agent Kit (TWAK) API Auth
TWAK_ACCESS_ID=your_trust_wallet_access_id
TWAK_HMAC_SECRET=your_trust_wallet_hmac_secret

# Telegram notifications
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# Agent settings
INITIAL_CAPITAL=1000.0
MAX_POSITION_PCT=5.0
MAX_EXPOSURE_PCT=60.0
DAILY_DRAWDOWN_HALT_PCT=8.0
COMPETITION_DRAWDOWN_CAP_PCT=25.0
SCAN_INTERVAL_SECONDS=3600
MONITOR_INTERVAL_SECONDS=300
