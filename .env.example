# Risk Guardrails
MAX_DRAWDOWN_PERCENT=25
MAX_POSITION_SIZE_PERCENT=5

# Unified Shared Wallet Credentials
ARBITER_PRIVATE_KEY="0xyour_testnet_private_key_here"
