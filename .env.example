# Arbiter — Track 2: Strategy Skills
# Copy this to .env and fill in your keys

# CoinMarketCap Agent Hub (for regime signals via MCP)
# Get free key at: https://pro.coinmarketcap.com/signup
CMC_API_KEY=your-cmc-api-key

# LLM API (set at least one — both are free, needed for optimizer)
# NVIDIA NIM: https://build.nvidia.com/settings/api-keys
NVIDIA_API_KEY=nvapi-...
# Google Gemini: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...
