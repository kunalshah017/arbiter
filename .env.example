# Network RPC Endpoints
BSC_RPC_URL="https://data-seed-prebsc-1-s1.binance.org:8545/"

# Trust Wallet API Authentication
TWAK_ACCESS_ID="your_trust_wallet_access_id"
TWAK_HMAC_SECRET="your_trust_wallet_hmac_secret"